# ---------------------------------------------------------------
# Redis (local dev: redis://localhost:6379 | prod: Upstash URL)
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------
# JWT (must match the secret configured in Supabase Auth → JWT Settings)
# ---------------------------------------------------------------
JWT_SECRET=

# ---------------------------------------------------------------
# Email provider (e.g. Resend or SendGrid API key)
# Used for digest emails dispatched via BullMQ (Phase 10)
# NOT for password reset — that is handled natively by Supabase Auth
# ---------------------------------------------------------------
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=noreply@trueassets.in

# ---------------------------------------------------------------
# SLA Engine defaults (configurable at runtime via AppSetting table)
# ---------------------------------------------------------------
SLA_DEFAULT_MINUTES=30
MAX_AUTO_REASSIGNMENTS=2

# ---------------------------------------------------------------
# Sentry (error tracking — especially for background jobs)
# ---------------------------------------------------------------
SENTRY_DSN=
